# ==========================================
# QUANTIS — Environment Variables
# Copy to .env and fill in actual values
# ==========================================
#
# SECURITY NOTES:
# - Never commit .env files with real secrets to version control
# - In production, use Docker secrets or a secrets manager (e.g. Vault, AWS SSM)
#   instead of plain-text .env files where possible.
#   See docker-compose.prod.yml for production configuration.
# - Generate JWT secrets with: openssl rand -base64 64
# - Generate encryption keys with: openssl rand -hex 32
#

# --- Global ---
NODE_ENV=development
LOG_LEVEL=info
APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# --- Service Ports ---
APP_PORT=3001
# PORT=3002  (data-collector)
# PORT=3003  (analysis-engine)
# PORT=3004  (alert-service)

# --- Database (PostgreSQL + TimescaleDB) ---
DB_HOST=localhost
DB_PORT=5433
DB_NAME=quantis
DB_USER=quantis
DB_PASSWORD=          # REQUIRED in production — no default allowed
DB_SSL=false
DB_POOL_MIN=5
DB_POOL_MAX=20

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6381
REDIS_PASSWORD=
REDIS_DB=0

# --- Authentication (REQUIRED — no defaults) ---
JWT_ACCESS_SECRET=    # REQUIRED — generate with: openssl rand -base64 64
JWT_REFRESH_SECRET=   # REQUIRED — generate with: openssl rand -base64 64
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# --- Exchange API Keys Encryption ---
API_KEY_ENCRYPTION_KEY=   # Generate with: openssl rand -hex 32

# --- Exchange Data Collection ---
BINANCE_API_URL=https://api.binance.com
BINANCE_WS_URL=wss://stream.binance.com:9443
BYBIT_API_URL=https://api.bybit.com
BYBIT_WS_URL=wss://stream.bybit.com
OKX_API_URL=https://www.okx.com
OKX_WS_URL=wss://ws.okx.com:8443

# --- Payment Gateway (NOWPayments) ---
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=true

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@quantis.io

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=

# --- AI Copilot (Anthropic) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
COPILOT_MAX_TOKENS=2000
COPILOT_TEMPERATURE=0.3

# --- Monitoring & Admin ---
ADMIN_EMAILS=andriipushkar@gmail.com
SENTRY_DSN=

# --- Production Only ---
# SSL_CERT_PATH=/etc/letsencrypt/live/quantis.io/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/quantis.io/privkey.pem
# DOMAIN=quantis.io
