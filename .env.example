# ==========================================
# QUANTIS — Environment Variables
# Copy to .env and fill in actual values
# ==========================================

# --- Global ---
NODE_ENV=development
LOG_LEVEL=info
APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# --- Database (PostgreSQL + TimescaleDB) ---
DB_HOST=localhost
DB_PORT=5433
DB_NAME=quantis
DB_USER=quantis
DB_PASSWORD=quantis_dev_password
DB_SSL=false
DB_POOL_MIN=5
DB_POOL_MAX=20

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6381
REDIS_PASSWORD=
REDIS_DB=0

# --- Authentication ---
JWT_ACCESS_SECRET=your-access-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# --- Exchange API Keys Encryption ---
API_KEY_ENCRYPTION_KEY=your-32-byte-hex-encoded-encryption-key

# --- Exchange Data Collection ---
BINANCE_API_URL=https://api.binance.com
BINANCE_WS_URL=wss://stream.binance.com:9443
BYBIT_API_URL=https://api.bybit.com
BYBIT_WS_URL=wss://stream.bybit.com
OKX_API_URL=https://www.okx.com
OKX_WS_URL=wss://ws.okx.com:8443

# --- Payment Gateway (NOWPayments) ---
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=true

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@quantis.io

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=

# --- AI Copilot (Anthropic) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
COPILOT_MAX_TOKENS=2000
COPILOT_TEMPERATURE=0.3

# --- Monitoring ---
ADMIN_EMAILS=admin@quantis.io
SENTRY_DSN=
